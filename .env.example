# 엔필름 환경변수 예시 — 이 파일은 커밋, .env.local 은 .gitignore
# 스텁 모드: 실제 외부 서비스 없이 인메모리/모킹으로 동작
NEXT_PUBLIC_USE_STUBS=true

# Supabase (스텁 모드에서는 빈 값 허용)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Kakao OAuth (스텁 모드에서는 빈 값 허용)
NEXT_PUBLIC_KAKAO_REST_KEY=
KAKAO_CLIENT_SECRET=
NEXT_PUBLIC_KAKAO_REDIRECT_URI=http://localhost:3000/api/auth/kakao/callback
